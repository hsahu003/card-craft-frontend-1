{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/confirmation/layout,_N_T_/confirmation/page,_N_T_/confirmation"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/confirmation/__PAGE__",
    "/confirmation",
    "/_index",
    "/_head"
  ]
}